# Backend
DATABASE_URL=postgresql://be_the_hero:be_the_hero@localhost:5432/be_the_hero
PORT=3000

# Auth (recommended)
# JWT_SECRET=change-me
# REFRESH_TOKEN_PEPPER=change-me
# CORS_ORIGINS=http://localhost:3001

# Seed
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=admin123

# Web
# In docker-compose, web uses NEXT_PUBLIC_API_URL=/api (proxy)
NEXT_PUBLIC_API_URL=/api
